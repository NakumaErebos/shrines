{
	"format_version": "1.8.0",
	"animations": {
		"animation.cryonis_pillar.grow": {
			"loop": "hold_on_last_frame",
			"animation_length": 0.5,
			"bones": {
				"bone": {
					"scale": {
						"0.0": {
							"vector": [1, 0, 1]
						},
						"0.5": {
							"vector": [1, 1, 1]
						}
					}
				}
			}
		},
		"animation.cryonis_pillar.break": {
			"animation_length": 0.5,
			"bones": {
				"bone": {
					"scale": {
						"0.0": {
							"vector": [1, 1, 1]
						},
						"0.5": {
							"vector": [0, 0, 0]
						}
					}
				}
			}
		}
	}
}