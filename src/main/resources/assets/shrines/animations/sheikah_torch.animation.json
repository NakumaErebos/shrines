{
	"format_version": "1.8.0",
	"animations": {
		"animation.sheikah_torch.idle": {
			"loop": "hold_on_last_frame",
			"bones": {
				"bone": {
					"scale": {
						"vector": [0, 0, 0]
					}
				}
			}
		},
		"animation.sheikah_torch.ignite": {
			"loop": "hold_on_last_frame",
			"animation_length": 0.5,
			"bones": {
				"bone": {
					"scale": {
						"0.0": {
							"vector": [0, 0, 0]
						},
						"0.5": {
							"vector": [1, 1, 1]
						}
					}
				}
			}
		},
		"animation.sheikah_torch.idle_ignited": {
			"loop": true
		},
		"animation.sheikah_torch.unignite": {
			"loop": "hold_on_last_frame",
			"animation_length": 0.5,
			"bones": {
				"bone": {
					"scale": {
						"0.0": {
							"vector": [1, 1, 1]
						},
						"0.5": {
							"vector": [0, 0, 0]
						}
					}
				}
			}
		}
	}
}